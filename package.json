{
  "name": "agent-mesh-service",
  "version": "1.0.0",
  "description": "Cloud agent mesh service for cross-platform agent communication via long-polling REST API",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "dev:mock": "MOCK_AUTH=true NODE_ENV=test node --watch src/index.js",
    "test": "node --test src/**/*.test.js",
    "test:integration": "node --test tests/integration/*.spec.js",
    "test:integration:tier1": "node --test tests/integration/tier1-init.spec.js",
    "test:integration:tier2": "node --test tests/integration/tier2-messaging.spec.js",
    "test:integration:tier3": "node --test tests/integration/tier3-copilot-e2e.spec.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:all": "npm run test && npm run test:integration && npm run test:e2e",
    "lint": "eslint src/",
    "deploy": "cdk deploy --require-approval never"
  },
  "keywords": [
    "agent-mesh",
    "long-polling",
    "multi-agent",
    "communication"
  ],
  "author": "htekdev",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "express-session": "^1.19.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "nanoid": "^5.0.9",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "stripe": "^22.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "aws-cdk": "^2.170.0",
    "aws-cdk-lib": "^2.170.0",
    "constructs": "^10.4.2",
    "eslint": "^9.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
