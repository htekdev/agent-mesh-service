  },
  "homepage": "https://meshwire.io",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "eslint": "^9.0.0"
  },
  "files": [
    "bin/",
    "src/",
    "README.md"
  ]
